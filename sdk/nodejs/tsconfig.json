{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "buildxBuilder.ts",
        "config/index.ts",
        "config/vars.ts",
        "container.ts",
        "getLogs.ts",
        "getNetwork.ts",
        "getPlugin.ts",
        "getRegistryImage.ts",
        "getRegistryImageManifests.ts",
        "getRemoteImage.ts",
        "image.ts",
        "index.ts",
        "network.ts",
        "plugin.ts",
        "provider.ts",
        "registryImage.ts",
        "remoteImage.ts",
        "secret.ts",
        "service.ts",
        "serviceConfig.ts",
        "tag.ts",
        "types/enums/index.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "volume.ts"
    ]
}
