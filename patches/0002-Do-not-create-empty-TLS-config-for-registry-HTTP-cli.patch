From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: guineveresaenger <guinevere@pulumi.com>
Date: Tue, 31 Mar 2026 16:11:32 -0700
Subject: [PATCH] Do not create empty TLS config for registry HTTP client

Use default TLS config for registry HTTP requests; only override when
insecureSkipVerify is set. In Go 1.25, an explicit empty tls.Config{}
produces a different TLS fingerprint than the default, which Docker
Hub's CDN rejects with 403 Forbidden.

Fixes: https://github.com/pulumi/pulumi-docker/issues/1648
Upstream: N/A
Test: examples/test-registry-image-dockerhub (TestRegistryImageDockerHub)

diff --git a/internal/provider/resource_docker_registry_image_funcs.go b/internal/provider/resource_docker_registry_image_funcs.go
index 7dbbfed..24ad3cc 100644
--- a/internal/provider/resource_docker_registry_image_funcs.go
+++ b/internal/provider/resource_docker_registry_image_funcs.go
@@ -311,15 +311,12 @@ func getAuthConfigForRegistry(
 }
 
 func buildHttpClientForRegistry(registryAddressWithProtocol string, insecureSkipVerify bool) *http.Client {
-	client := http.DefaultClient
-
-	if strings.HasPrefix(registryAddressWithProtocol, "https://") {
-		client.Transport = &http.Transport{TLSClientConfig: &tls.Config{InsecureSkipVerify: insecureSkipVerify}, Proxy: http.ProxyFromEnvironment}
-	} else {
-		client.Transport = &http.Transport{Proxy: http.ProxyFromEnvironment}
+	if insecureSkipVerify && strings.HasPrefix(registryAddressWithProtocol, "https://") {
+		return &http.Client{
+			Transport: &http.Transport{TLSClientConfig: &tls.Config{InsecureSkipVerify: true}, Proxy: http.ProxyFromEnvironment},
+		}
 	}
-
-	return client
+	return http.DefaultClient
 }
 
 func deleteDockerRegistryImage(pushOpts internalPushImageOptions, registryWithProtocol string, sha256Digest, username, password string, insecureSkipVerify, fallback bool) error {
